cors.allowed.origins=http://localhost:5173
cors.allowed.methods=GET,POST,PUT,DELETE,OPTIONS
cors.allowed.headers=Content-Type,X-Requested-With,Authorization
cors.allow.credentials=true

# JWT 配置
jwt.secret=your-secret-key-at-least-32-bytes-long
jwt.expiration=604800

# Email 配置 (SMTP)
mail.smtp.host=smtp.example.com
mail.smtp.port=465
mail.smtp.username=your-email@example.com
mail.smtp.password=your-password
mail.from=your-email@example.com
mail.ssl.enable=true

# Turnstile 配置
# 暂时用测试 key: 1x0000000000000000000000000000000AA
turnstile.secret=your-turnstile-secret-key
